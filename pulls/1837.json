      "starred_url": "https://api.github.com/users/mllwchrry/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/mllwchrry/subscriptions",
      "organizations_url": "https://api.github.com/users/mllwchrry/orgs",
      "repos_url": "https://api.github.com/users/mllwchrry/repos",
      "events_url": "https://api.github.com/users/mllwchrry/events%7B/privacy%7D",
